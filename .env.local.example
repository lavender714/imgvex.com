# Supabase Project URL (from Supabase Dashboard → Project Settings → Data API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon Key (from Supabase Dashboard → Project Settings → Data API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key — server-only, used by Creem webhook to bypass RLS
# (Project Settings → Data API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cloudflare R2 (from R2 Object Storage → Account API Tokens)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=your-bucket-name
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key

# APIPod (from https://www.apipod.ai/console/api-keys)
APIPOD_API_KEY=sk-your-apipod-api-key
APIPOD_BASE_URL=https://api.apipod.ai/v1

# KIE (from https://kie.ai dashboard)
KIE_API_KEY=sk-your-kie-api-key
KIE_BASE_URL=https://kie.ai/api/v1

# EvoLink (from https://evolink.ai/dashboard/keys)
# Used as 3rd-tier failover after APIPod / KIE
EVOLINK_API_KEY=sk-your-evolink-api-key
EVOLINK_BASE_URL=https://api.evolink.ai

# ─── Creem billing ──────────────────────────────────────────────
# Dashboard: https://creem.io/dashboard (toggle test mode for sandbox keys)
CREEM_API_KEY=creem_live_xxx
CREEM_WEBHOOK_SECRET=whsec_xxx

# Creem test mode API key — only needed when CREEM_TEST_MODE=true.
# Get this from the Creem dashboard after switching to Test mode.
CREEM_TEST_API_KEY=creem_test_xxx

# Set to "true" to use Creem test mode (checkout.creem.io).
# In Next.js, NODE_ENV is always "production" after build, so we use this
# explicit flag instead of relying on NODE_ENV.
CREEM_TEST_MODE=true

# Client-side mirror of CREEM_TEST_MODE so the pricing page can swap
# product IDs between test and production.
NEXT_PUBLIC_CREEM_TEST_MODE=true

# Creem product IDs — one per tier × billing period.
# Create products in the Creem dashboard, then paste the prod_xxx ids here.
# NEXT_PUBLIC_ prefix because the pricing page (client) reads them to build checkout URLs.
NEXT_PUBLIC_CREEM_PRODUCT_LITE_MONTHLY=prod_xxx
NEXT_PUBLIC_CREEM_PRODUCT_LITE_YEARLY=prod_xxx
NEXT_PUBLIC_CREEM_PRODUCT_PRO_MONTHLY=prod_xxx
NEXT_PUBLIC_CREEM_PRODUCT_PRO_YEARLY=prod_xxx
NEXT_PUBLIC_CREEM_PRODUCT_ULTRA_MONTHLY=prod_xxx
NEXT_PUBLIC_CREEM_PRODUCT_ULTRA_YEARLY=prod_xxx

# One-time credit packs (never expire). ~$0.035-0.04/credit (3.5-4x cost):
#   PACK_S = $19 / 500 · PACK_M = $79 / 2,000 · PACK_L = $349 / 10,000
# Create these as ONE-TIME products in Creem (not recurring). Names are
# size-agnostic so re-pricing doesn't require renaming env vars.
NEXT_PUBLIC_CREEM_PRODUCT_PACK_S=prod_xxx
NEXT_PUBLIC_CREEM_PRODUCT_PACK_M=prod_xxx
NEXT_PUBLIC_CREEM_PRODUCT_PACK_L=prod_xxx

# Test-mode product ids — only needed when CREEM_TEST_MODE=true.
NEXT_PUBLIC_CREEM_PRODUCT_LITE_MONTHLY_TEST=prod_test_xxx
NEXT_PUBLIC_CREEM_PRODUCT_LITE_YEARLY_TEST=prod_test_xxx
NEXT_PUBLIC_CREEM_PRODUCT_PRO_MONTHLY_TEST=prod_test_xxx
NEXT_PUBLIC_CREEM_PRODUCT_PRO_YEARLY_TEST=prod_test_xxx
NEXT_PUBLIC_CREEM_PRODUCT_ULTRA_MONTHLY_TEST=prod_test_xxx
NEXT_PUBLIC_CREEM_PRODUCT_ULTRA_YEARLY_TEST=prod_test_xxx
NEXT_PUBLIC_CREEM_PRODUCT_PACK_S_TEST=prod_test_xxx
NEXT_PUBLIC_CREEM_PRODUCT_PACK_M_TEST=prod_test_xxx
NEXT_PUBLIC_CREEM_PRODUCT_PACK_L_TEST=prod_test_xxx

# 本地开发复制此文件为 .env.local 并填入真实值
# 生产环境在 Vercel/服务器上单独配置
