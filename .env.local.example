# Supabase Project URL (from Supabase Dashboard → Project Settings → Data API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon Key (from Supabase Dashboard → Project Settings → Data API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key — server-only, used by Creem webhook to bypass RLS
# (Project Settings → Data API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cloudflare R2 (from R2 Object Storage → Account API Tokens)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=your-bucket-name
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key

# APIPod (from https://www.apipod.ai/console/api-keys)
APIPOD_API_KEY=sk-your-apipod-api-key
APIPOD_BASE_URL=https://api.apipod.ai/v1

# ─── Creem billing ──────────────────────────────────────────────
# Dashboard: https://creem.io/dashboard (toggle test mode for sandbox keys)
CREEM_API_KEY=creem_test_xxx
CREEM_WEBHOOK_SECRET=whsec_xxx

# Creem product IDs — one per tier × billing period.
# Create products in the Creem dashboard, then paste the prod_xxx ids here.
# NEXT_PUBLIC_ prefix because the pricing page (client) reads them to build checkout URLs.
NEXT_PUBLIC_CREEM_PRODUCT_LITE_MONTHLY=prod_xxx
NEXT_PUBLIC_CREEM_PRODUCT_LITE_YEARLY=prod_xxx
NEXT_PUBLIC_CREEM_PRODUCT_PRO_MONTHLY=prod_xxx
NEXT_PUBLIC_CREEM_PRODUCT_PRO_YEARLY=prod_xxx
NEXT_PUBLIC_CREEM_PRODUCT_ULTRA_MONTHLY=prod_xxx
NEXT_PUBLIC_CREEM_PRODUCT_ULTRA_YEARLY=prod_xxx

# 本地开发复制此文件为 .env.local 并填入真实值
# 生产环境在 Vercel/服务器上单独配置
