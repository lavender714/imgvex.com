# Supabase Project URL (from Supabase Dashboard → Project Settings → Data API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon Key (from Supabase Dashboard → Project Settings → Data API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Cloudflare R2 (from R2 Object Storage → Account API Tokens)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=your-bucket-name
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key

# 本地开发复制此文件为 .env.local 并填入真实值
# 生产环境在 Vercel/服务器上单独配置
